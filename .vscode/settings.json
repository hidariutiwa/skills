{
	"git.autofetch": true,
	"redhat.telemetry.enabled": true,
	"git.confirmSync": false,
	"workbench.colorTheme": "Tokyo Night Storm",
	"tabnine.experimentalAutoImports": true,
	"editor.accessibilitySupport": "on",
	"[python]": {
		"editor.formatOnType": true,
		"editor.defaultFormatter": "ms-python.black-formatter"
	},
	"editor.fontSize": 12,
	"hediet.vscode-drawio.resizeImages": null,
	"security.workspace.trust.untrustedFiles": "open",
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"bladeFormatter.format.indentSize": 8,
	"editor.detectIndentation": false,
	"workbench.startupEditor": "none",
	"accessibility.voice.speechLanguage": "ja-JP",
	"javascript.updateImportsOnFileMove.enabled": "never",
	"prettier.withNodeModules": true,
	"debug.javascript.terminalOptions": {},
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[css]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"explorer.confirmDelete": false,
	"editor.formatOnSave": true,
	"[sql]": {
		"editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode"
	},
	"[dart]": {
		"editor.tabSize": 4,
		"editor.detectIndentation": false,
		"editor.suggest.insertMode": "replace",
		"editor.inlayHints.enabled": "offUnlessPressed",
		"editor.defaultFormatter": "Dart-Code.flutter"
	},
	"plantuml.server": "https://www.plantuml.com/plantuml",
	"plantuml.render": "PlantUMLServer",
	"dineug.erd-editor.theme.appearance": "light",
	"dineug.erd-editor.theme.grayColor": "sand",
	"dineug.erd-editor.theme.accentColor": "blue",
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"workbench.editor.empty.hint": "hidden",
	"geminicodeassist.inlineSuggestions.enableAuto": true,
	"diffEditor.codeLens": true,
